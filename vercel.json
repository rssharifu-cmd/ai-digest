{
  "version": 2,
  "rewrites": [
    { "source": "/api/auth", "destination": "/api/auth.js" },
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/send", "destination": "/api/send.js" },
    { "source": "/api/user", "destination": "/api/user.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
